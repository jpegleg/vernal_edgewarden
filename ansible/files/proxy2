#!/usr/bin/env sh
CMDZ="$1"
PROCNM="kiaproxy2"

export LISTENER=127.0.0.1:4003
export SERVERS=127.0.0.1:3003

skillo() {
  pkill $PROCNM && pgrep $PROCNM && pkill -9 $PROCNM
}

if [ "$CMDZ" == "start" ]; then
  pgrep $PROCNM || ed /root && /root/kiaproxy2 > /dev/null 2>&1 &
  # use this instead for log event output
  #pgrep $PROCNM || cd /root && /root/kiaproxy2 > /var/log/kiaproxy2.log 2>&1 &
fi
if [ "$CMDZ" == "restart" ]; then
  skillo && cd /root && /root/kiaproxy2 > /dev/null 2>&1 &
  # use this instead for log event output
  #skillo && cd /root && /root/kiaproxy2 > /var/log/kiaproxy2.log 2>&1 &
fi
if [ "$CMDZ" == "stop" ]; then
  skillo
fi

